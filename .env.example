PORT=3000
NODE_ENV=development
LOG_LEVEL=info
JWT_SECRET=replace-me-with-a-long-secret
JWT_REFRESH_SECRET=replace-me-with-a-long-refresh-secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=iot_platform
POSTGRES_USER=iot_user
POSTGRES_PASSWORD=change-me
PG_POOL_MAX=20
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=5000
PG_STATEMENT_TIMEOUT_MS=30000
REDIS_HOST=localhost
REDIS_PORT=6379
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=iot-platform-backend
OFFLINE_THRESHOLD_MS=90000
OFFLINE_CHECK_INTERVAL_MS=30000
COMMAND_DISPATCH_INTERVAL_MS=5000
COMMAND_ACK_TIMEOUT_MS=30000
COMMAND_DEFAULT_MAX_ATTEMPTS=3
RULE_WEBHOOK_TIMEOUT_MS=5000
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@iot-platform.local
WEBHOOK_NOTIFICATION_TIMEOUT_MS=5000
NOTIFICATION_DISPATCH_INTERVAL_MS=5000
NOTIFICATION_DEFAULT_MAX_ATTEMPTS=3
NOTIFICATION_RETRY_BACKOFF_MS=30000
REPORT_DISPATCH_INTERVAL_MS=60000
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=iot-platform
MINIO_USE_SSL=false
FIRMWARE_MAX_SIZE_BYTES=104857600
LOG_MAX_SIZE_BYTES=20971520
PLUGINS_DIR=plugins
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=2000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
# Leave unset/false in production — see docs/architecture.md's Production Hardening
# section. Only needed for local dev/test workflows that deliberately point a webhook
# at a loopback address.
ALLOW_PRIVATE_WEBHOOK_TARGETS=false
