# Production environment template for docker-compose.prod.yml.
# Copy to `.env`, then fill in every REQUIRED value — none of them have a usable
# default in production the way .env.example's dev fallbacks do.
# Run scripts/generate-secrets.sh to generate strong values for the secrets below.

PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# REQUIRED — generate via scripts/generate-secrets.sh. The application falls back to
# an obviously-fake dev secret if these are unset; never run production on that fallback.
JWT_SECRET=
JWT_REFRESH_SECRET=

# Hostnames below are Docker Compose service names (see docker-compose.prod.yml) —
# containers reach each other by service name on the compose network, not localhost.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=iot_platform
POSTGRES_USER=iot_user
# REQUIRED — generate via scripts/generate-secrets.sh.
POSTGRES_PASSWORD=
PG_POOL_MAX=20
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=5000
PG_STATEMENT_TIMEOUT_MS=30000

REDIS_HOST=redis
REDIS_PORT=6379

MQTT_HOST=emqx
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=iot-platform-backend

OFFLINE_THRESHOLD_MS=90000
OFFLINE_CHECK_INTERVAL_MS=30000
COMMAND_DISPATCH_INTERVAL_MS=5000
COMMAND_ACK_TIMEOUT_MS=30000
COMMAND_DEFAULT_MAX_ATTEMPTS=3
RULE_WEBHOOK_TIMEOUT_MS=5000

# Point at a real mail provider — there is no Mailpit-equivalent in production.
SMTP_HOST=smtp.your-provider.example
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@your-domain.example
WEBHOOK_NOTIFICATION_TIMEOUT_MS=5000
NOTIFICATION_DISPATCH_INTERVAL_MS=5000
NOTIFICATION_DEFAULT_MAX_ATTEMPTS=3
NOTIFICATION_RETRY_BACKOFF_MS=30000

REPORT_DISPATCH_INTERVAL_MS=60000

MINIO_ENDPOINT=minio
MINIO_PORT=9000
# REQUIRED — generate via scripts/generate-secrets.sh. Do not ship with the
# minioadmin/minioadmin dev defaults.
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=iot-platform
MINIO_USE_SSL=false

FIRMWARE_MAX_SIZE_BYTES=104857600
LOG_MAX_SIZE_BYTES=20971520
PLUGINS_DIR=plugins

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=2000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# Deliberately omitted: ALLOW_PRIVATE_WEBHOOK_TARGETS. Never set this in production —
# see docs/architecture.md's Production Hardening section. It exists only for this
# project's own webhook tests, which deliberately target a local test server.
